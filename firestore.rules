rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only the pvgc collection is used by this app.
    // Require a valid Firebase Auth token (anonymous sign-in is enough).
    match /pvgc/{docId} {
      allow read, write: if request.auth != null;

      match /weekScores/{scoreId} {
        allow read, write: if request.auth != null;
      }

      match /snapshots/{snapId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
